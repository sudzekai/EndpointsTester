<UserControl x:Class="EndpointsTester.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EndpointsTester.Views"
             mc:Ignorable="d" 
             MaxWidth="1200">
    <Border Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                    <TextBlock Text="Endpoints Tester"
                           FontWeight="Bold"
                           FontSize="20"/>  
            </Border>

            <Border Grid.Row="1"
                    Padding="10"
                    Margin="0,10,0,0"
                    CornerRadius="5"
                    BorderThickness="1"
                    BorderBrush="Black">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="10*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding Methods}"
                              SelectedItem="{Binding SelectedMethod}"/>

                    <ComboBox IsEditable="True" 
                              Grid.Column="1"
                              ItemsSource="{Binding UrlsHistory}"
                              Text="{Binding Url}"
                              Margin="10,0,0,0"/>
                </Grid>
            </Border>
            
            <Border Grid.Row="2"
                    Padding="5"
                    Margin="0,10,0,0"
                    CornerRadius="5"
                    BorderThickness="1"
                    BorderBrush="Black">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                        
                    <TextBlock Text="Заголовки"
                               FontWeight="SemiBold"
                               FontSize="18"/>

                    <Border Padding="5"
                            Grid.Row="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>

                            <ScrollViewer Margin="0,0,0,5" 
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Headers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3*"/>
                                                    <ColumnDefinition Width="8*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBox Grid.Column="0"
                                                     Text="{Binding Name}"
                                                     VerticalContentAlignment="Center"
                                                     Margin="0,0,5,0"/>

                                                <TextBox Grid.Column="1"
                                                     Text="{Binding Value}"
                                                     VerticalContentAlignment="Center"/>

                                                <Button Grid.Column="2"
                                                    Content="✖"
                                                    Margin="5,0,0,0"
                                                    Command="{Binding DataContext.RemoveHeaderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Name}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <Button Content="+ Добавить"
                                    Height="30"
                                    Grid.Row="1"
                                    Command="{Binding AddHeaderCommand}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Padding="5"
                    Margin="0,10,0,0"
                    CornerRadius="5"
                    BorderThickness="1"
                    BorderBrush="Black">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Тело запроса"
                               FontWeight="SemiBold"
                               FontSize="18"/>

                    <Border Grid.Row="1" 
                            Padding="5">
                        <TextBox Text="{Binding Body}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 FontFamily="Consolas"
                                 KeyDown="BodyTextBox_KeyDown"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    Margin="0,10,0,0"
                    Padding="5">
                <Button Content="Отправить запрос"
                        Command="{Binding SendRequestCommand}"
                        Height="30"/>
            </Border>
            
            <Border Grid.Row="5"
                    Padding="5"
                    Margin="0,10,0,0"
                    CornerRadius="5"
                    BorderThickness="1"
                    BorderBrush="Black">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid ColumnDefinitions="auto,auto">
                        <TextBlock Text="Ответ"
                                   FontWeight="SemiBold"
                                   FontSize="18"/>
                        <TextBlock Margin="5,0,0,0" 
                                   Grid.Column="1"
                                   Text="{Binding Response}"
                                   Foreground="{Binding ResponseBrush}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   FontSize="18"/>
                    </Grid>
         

                    <Border Padding="5"
                            Grid.Row="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0"
                                  Margin="0,0,5,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Заголовки"
                                           FontWeight="SemiBold"
                                           FontSize="16"/>
                                
                                <Border Grid.Row="1"
                                        Margin="0,5,0,0"
                                        Padding="5"
                                        BorderThickness="1"
                                        BorderBrush="#ccc">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBlock Text="{Binding ResponseHeaders}"
                                                   TextWrapping="Wrap"/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                            
                            <Grid Grid.Column="1"
                                  Margin="0,0,5,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Тело"
                                           FontWeight="SemiBold"
                                           FontSize="16"/>
                                
                                <Border Grid.Row="1"
                                        Margin="0,5,0,0"
                                        Padding="5"
                                        BorderThickness="1"
                                        BorderBrush="#ccc">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBlock Text="{Binding ResponseBody}"
                                                   TextWrapping="Wrap"/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
                
            </Border>
        </Grid>
    </Border>
</UserControl>
